{
  "name": "@ministryofmany/minister-verify",
  "version": "0.1.0",
  "description": "Server-side Minister id_token + badge verifier built on @ministryofmany/client, returning sub + verified badges for policy evaluation.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "author": "AtHeartEngineer",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ministryofmany/client": "workspace:*",
    "@ministryofmany/policy": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "jose": "^5.9.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
