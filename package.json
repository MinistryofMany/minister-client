{
  "name": "@ministryofmany/client",
  "version": "0.1.0",
  "description": "TypeScript SDK for OIDC relying parties authenticating users via Minister and consuming W3C verifiable-credential badges.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "author": "AtHeartEngineer",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth-js": {
      "types": "./dist/auth-js.d.ts",
      "import": "./dist/auth-js.js"
    },
    "./badges": {
      "types": "./dist/badges/index.d.ts",
      "import": "./dist/badges/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "pnpm -r --if-present typecheck:tests",
    "check:links": "node scripts/check-workspace-links.mjs",
    "pretest": "node scripts/check-workspace-links.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@auth/core": "^0.37.0"
  },
  "peerDependenciesMeta": {
    "@auth/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@auth/core": "^0.37.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "underscore@<1.13.8": ">=1.13.8"
    }
  },
  "packageManager": "pnpm@9.12.0"
}
